# ─────────────────────────────────────────────────────────────
# CTI Aggregator — Environment variables
# Copy to .env and fill in all values before running make up
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cti
POSTGRES_USER=cti
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password

# ── Ollama ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=llama3.3:70b-instruct-q4_K_M
LLM_FALLBACK_MODEL=mistral:7b-instruct-q4_K_M
LLM_TIMEOUT_SECONDS=120
LLM_NUM_CTX=8192

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
DEDUP_SEMANTIC_THRESHOLD=0.92

# ── JWT ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(64)).decode())"
JWT_SECRET=change_me_generate_64_random_bytes_base64
JWT_EXPIRE_HOURS=8

# ── Application ───────────────────────────────────────────────
BASE_URL=https://cti.your-org.internal
LOG_LEVEL=INFO
# Module name — injected by docker-compose per service, do not set manually here
# MODULE_NAME=

# ── Collector ─────────────────────────────────────────────────
FETCH_DEDUP_TTL_SECONDS=604800       # 7 days
MAX_PDF_SIZE_MB=50
MIN_CONTENT_WORDS=100
CHUNK_MAX_TOKENS=3000
CHUNK_OVERLAP_TOKENS=200
OCR_ENABLED=true

# ── Validator ─────────────────────────────────────────────────
# Comma-separated list of source categories that receive trusted score (40pts)
TRUSTED_SOURCE_CATEGORIES=trusted
# Comma-separated list for known score (20pts)
KNOWN_SOURCE_CATEGORIES=known

# ── Retention ─────────────────────────────────────────────────
RETENTION_DAYS=60
PURGE_CRON=0 2 * * *    # Daily at 02:00

# ── SMTP ──────────────────────────────────────────────────────
SMTP_HOST=your-smtp-relay.internal
SMTP_PORT=25
SMTP_FROM=cti-aggregator@your-org.internal
ALERT_RECIPIENTS=soc@your-org.internal

# ── External API keys (optional — enrichment disabled if absent) ──
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
MISP_BASE_URL=
MISP_API_KEY=
